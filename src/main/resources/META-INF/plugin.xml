<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.c211007.androidstudiokoreanlanguagepack</id>
    <name>Korean Language Pack</name>
    <vendor email="c211007@gmail.com" url="https://github.com/c211007">c211007</vendor>
    <category>Localization</category>
    <description>안드로이드 스튜디오 한국어 언어팩

Korean language pack for Android Studio. After installation, go to Settings > Appearance &amp; Behavior > Language and Region > Language to select Korean.

설치 후 설정 > 모양 및 동작 > 언어 및 지역 > 언어에서 한국어를 선택하세요.</description>

    <!-- Minimum version requirement -->
    <idea-version since-build="242" />

    <!-- Core platform dependency only -->
    <depends>com.intellij.modules.platform</depends>
    <!-- Android Studio specific modules (optional) -->
    <depends optional="true" config-file="plugin-android.xml">org.jetbrains.android</depends>

    <!-- Resource bundles - explicit registration for Korean translations -->
    <resource-bundle>messages.ActionsBundle</resource-bundle>
    <resource-bundle>messages.AndroidBundle</resource-bundle>
    <resource-bundle>messages.AndroidLintBundle</resource-bundle>
    <resource-bundle>messages.ApplicationBundle</resource-bundle>
    <resource-bundle>messages.CodeInsightBundle</resource-bundle>
    <resource-bundle>messages.CommonBundle</resource-bundle>
    <resource-bundle>messages.DiffBundle</resource-bundle>
    <resource-bundle>messages.EditorBundle</resource-bundle>
    <resource-bundle>messages.ExecutionBundle</resource-bundle>
    <resource-bundle>messages.FindBundle</resource-bundle>
    <resource-bundle>messages.IdeBundle</resource-bundle>
    <resource-bundle>messages.LangBundle</resource-bundle>
    <resource-bundle>messages.LayoutInspectorBundle</resource-bundle>
    <resource-bundle>messages.LogcatBundle</resource-bundle>
    <resource-bundle>messages.OptionsBundle</resource-bundle>
    <resource-bundle>messages.ProjectBundle</resource-bundle>
    <resource-bundle>messages.RefactoringBundle</resource-bundle>
    <resource-bundle>messages.UIBundle</resource-bundle>

    <!-- Language bundle extension to enable Korean in Settings -->
    <extensions defaultExtensionNs="com.intellij">
        <languageBundle locale="ko"/>
    </extensions>

    <!-- Test action to verify plugin is loaded -->
    <actions>
        <action id="com.github.c211007.androidstudiokoreanlanguagepack.TestLanguagePackAction"
                class="com.github.c211007.androidstudiokoreanlanguagepack.TestLanguagePackAction"
                text="Test Korean Language Pack"
                description="Test if the Korean language pack plugin is loaded">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

</idea-plugin>
