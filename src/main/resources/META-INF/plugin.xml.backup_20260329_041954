<!-- Language bundle extension to enable Korean in Settings -->
    <extensions defaultExtensionNs="com.intellij">
        <languageBundle locale="ko"/>

        <!-- Notification group for language change prompt -->
        <notificationGroup id="Korean Language Pack"
                           displayType="STICKY_BALLOON"
                           isLogByDefault="true"/>

        <!-- Project activity to show language change notification -->
        <projectActivity implementation="com.github.c211007.androidstudiokoreanlanguagepack.KoreanLanguagePackNotifier"/>
    </extensions>

    <!-- Test action to verify plugin is loaded -->
    <actions>
        <action id="com.github.c211007.androidstudiokoreanlanguagepack.TestLanguagePackAction"
                class="com.github.c211007.androidstudiokoreanlanguagepack.TestLanguagePackAction"
                text="Test Korean Language Pack"
                description="Test if the Korean language pack plugin is loaded">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

</idea-plugin>
